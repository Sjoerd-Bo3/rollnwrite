{
  "game": "qwixx",
  "variant": "connected",
  "config": { "scoringCap": 12 },
  "name": "concede-finish",
  "description": "Concede locks a row with no lock bonus, conceded rows count toward the two-lock game end, finish ends the game immediately, and both are exactly undoable. A conceded row's marks (from earlier chain co-marks or direct crosses) are untouched by the concede itself.",
  "steps": [
    { "do": "markColor", "color": "red", "index": 4, "expect": true, "note": "red[4] (red 6), chained to yellow[4] - auto-crosses yellow 6 too" },
    { "assert": { "crosses": { "red": 1, "yellow": 1 } } },

    { "do": "concede", "color": "red", "expect": true, "note": "another player locked red - close it for free; red's existing mark is untouched" },
    { "assert": {
        "rowLocked": { "red": true },
        "lockedRowCount": 1,
        "crosses": { "red": 1 },
        "points": { "red": 1 },
        "totalScore": 2,
        "isGameOver": false
    } },

    { "do": "concede", "color": "red", "expect": false, "note": "cannot concede an already-locked row" },
    { "do": "markColor", "color": "red", "index": 5, "expect": false, "note": "conceded row refuses direct marks" },

    { "do": "undo", "expect": true, "note": "undo the concede - row reopens" },
    { "assert": {
        "rowLocked": { "red": false },
        "lockedRowCount": 0,
        "crosses": { "red": 1 },
        "isGameOver": false,
        "canRedo": true
    } },

    { "do": "concede", "color": "red", "expect": true, "note": "fresh move clears the redo stack" },
    { "assert": { "canRedo": false, "lockedRowCount": 1 } },

    { "do": "concede", "color": "yellow", "expect": true, "note": "second locked row - conceded rows count toward game end; yellow keeps its chain-derived mark" },
    { "assert": {
        "lockedRowCount": 2,
        "isGameOver": true,
        "crosses": { "yellow": 1 },
        "points": { "yellow": 1 },
        "totalScore": 2
    } },

    { "do": "undo", "expect": true, "note": "undo the yellow concede - play resumes" },
    { "assert": { "lockedRowCount": 1, "isGameOver": false } },

    { "do": "finish", "expect": true, "note": "manual finish ends the game immediately" },
    { "assert": { "isGameOver": true, "lockedRowCount": 1, "totalScore": 2 } },

    { "do": "markColor", "color": "green", "index": 0, "expect": false, "note": "green[0] (green 12) is not a chain space, but the game is over so it's refused anyway" },

    { "do": "undo", "expect": true, "note": "undo the finish - play resumes" },
    { "assert": { "isGameOver": false, "canRedo": true } },

    { "do": "redo", "expect": true, "note": "redo re-applies the finish" },
    { "assert": { "isGameOver": true, "totalScore": 2 } }
  ]
}
