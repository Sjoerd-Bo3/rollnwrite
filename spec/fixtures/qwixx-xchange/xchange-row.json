{
  "game": "qwixx",
  "variant": "xchange",
  "config": { "scoringCap": 12 },
  "name": "xchange-row",
  "description": "The X-Change row is crossed strictly left-to-right on its own independent track: skipping forfeits lower fields forever, marking colour rows does not affect it, and it freezes once the game ends.",
  "steps": [
    { "do": "markXChange", "index": 3, "expect": true, "note": "skip fields 0-2 to reach field 3" },
    { "assert": { "xchangeCrossed": 1, "xchangeMarks": [3] } },
    { "do": "markXChange", "index": 1, "expect": false, "note": "index 1 < maxMarkedIndex 3 - forfeited forever" },
    { "do": "markXChange", "index": 3, "expect": false, "note": "already marked" },
    { "assert": { "xchangeCrossed": 1, "xchangeMarks": [3], "canUndo": true } },
    { "do": "markXChange", "index": 4, "expect": true },
    { "do": "markXChange", "index": 5, "expect": true },
    { "assert": { "xchangeCrossed": 3, "xchangeMarks": [3, 4, 5] } },
    { "do": "markColor", "color": "red", "index": 0, "expect": true, "note": "colour marks never interact with the X-Change track" },
    { "assert": { "xchangeCrossed": 3, "xchangeMarks": [3, 4, 5], "crosses": { "red": 1 } } },
    { "do": "undo", "expect": true, "note": "LIFO: undoes the red mark, not an X-Change field" },
    { "assert": { "xchangeCrossed": 3, "xchangeMarks": [3, 4, 5], "crosses": { "red": 0 } } },
    { "do": "undo", "expect": true, "note": "undoes X-Change field 5" },
    { "assert": { "xchangeCrossed": 2, "xchangeMarks": [3, 4], "canRedo": true } },
    { "do": "markXChange", "index": 1, "expect": false, "note": "still forfeited even after the undo - maxMarkedIndex is now 4, still > 1" },
    { "do": "redo", "expect": true, "note": "redo re-applies field 5 exactly" },
    { "assert": { "xchangeCrossed": 3, "xchangeMarks": [3, 4, 5] } },
    { "do": "markColor", "color": "yellow", "index": 0, "expect": true },
    { "do": "markColor", "color": "yellow", "index": 1, "expect": true },
    { "do": "markColor", "color": "yellow", "index": 2, "expect": true },
    { "do": "markColor", "color": "yellow", "index": 3, "expect": true },
    { "do": "markColor", "color": "yellow", "index": 4, "expect": true },
    { "do": "markColor", "color": "yellow", "index": 10, "expect": true, "note": "locks yellow" },
    { "do": "concede", "color": "green", "expect": true, "note": "second locked row - game ends" },
    { "assert": { "isGameOver": true, "lockedRowCount": 2 } },
    { "do": "markXChange", "index": 8, "expect": false, "note": "X-Change freezes exactly like colour rows once the game is over" },
    { "assert": { "xchangeCrossed": 3, "xchangeMarks": [3, 4, 5] } }
  ]
}
