    "Tap once to circle, twice to cross. Score counts crosses: %lld → %lld": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik één keer om te omcirkelen, twee keer om te kruisen. De score telt kruisjes: %lld → %lld"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmal tippen zum Einkreisen, zweimal zum Ankreuzen. Gewertet werden Kreuze: %lld → %lld"
          }
        }
      }
    },
    "Outermost left + outermost right + 4 per 2/3/4/10/11/12.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Meest links + meest rechts + 4 per 2/3/4/10/11/12."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Äußerste links + äußerste rechts + 4 je 2/3/4/10/11/12."
          }
        }
      }
    },
    "Enter the value you wrote (die × the shown multiplier, or the halved bonus value).": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer de waarde in die je opschreef (dobbelsteen × de getoonde vermenigvuldiger, of de gehalveerde bonuswaarde)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib den notierten Wert ein (Würfel × angezeigter Multiplikator oder den halbierten Bonuswert)."
          }
        }
      }
    },
