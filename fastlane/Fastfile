# RollnWrite — browser-only TestFlight pipeline
#
# Inspired by the Loop/Trio fastlane setup, simplified for a single-target app:
# Apple's *cloud signing* (`-allowProvisioningUpdates` + an App Store Connect
# API key) manages the distribution certificate and provisioning profile on
# Apple's servers, so there is NO `match`, no `Match-Secrets` repo, no
# `GH_PAT`, and no `MATCH_PASSWORD` to manage. Everything runs on a
# GitHub-hosted Mac — see docs/TESTFLIGHT.md. No local Mac required.
#
# Required environment (provided as GitHub secrets in the workflow):
#   APPLE_TEAM_ID  ASC_KEY_ID  ASC_ISSUER_ID  ASC_KEY_P8  APP_BUNDLE_ID

default_platform(:ios)

PROJECT = "RollnWrite.xcodeproj"
SCHEME  = "RollnWrite"

# Bundle id and Team ID are not secret (they ship inside every app binary), so
# they live in the project. The env vars are optional overrides — if a secret
# isn't set, we fall back to these committed defaults.
DEFAULT_BUNDLE_ID = "dev.bo3.RollnWrite"
DEFAULT_TEAM_ID   = "794HF2GP3T"

# An unset GitHub secret still arrives as an empty string (the workflow passes
# `KEY: ${{ secrets.KEY }}`), so treat blank the same as missing and use the
# committed default.
def env_or(name, fallback)
  v = ENV[name]
  v.nil? || v.strip.empty? ? fallback : v.strip
end

def bundle_id
  env_or("APP_BUNDLE_ID", DEFAULT_BUNDLE_ID)
end

def team_id
  env_or("APPLE_TEAM_ID", DEFAULT_TEAM_ID)
end

require "base64"
require "openssl"
require "tmpdir"

# Rebuild a clean PEM from the ASC_KEY_P8 secret no matter how it was pasted.
# Handles every common form so "invalid curve name" can't happen:
#   • a normal PEM (with real newlines)
#   • a PEM whose newlines were collapsed to spaces or escaped to literal "\n"
#   • the bare base64 body with the -----BEGIN/END----- lines deleted
#   • the whole .p8 file base64-encoded into one line
# In every case we extract the raw base64 key body and re-wrap it at 64 chars
# inside fresh BEGIN/END markers, which OpenSSL parses reliably.
def clean_p8_pem(raw)
  # Unescape literal "\n"/CRLF FIRST so a one-line secret becomes real text and
  # no stray characters survive into the base64 body.
  raw = raw.to_s.strip.gsub('\\r\\n', "\n").gsub('\\n', "\n").gsub("\r\n", "\n")

  text =
    if raw.include?("PRIVATE KEY")
      raw
    else
      decoded = (Base64.decode64(raw) rescue "")
      decoded.include?("PRIVATE KEY") ? decoded : raw # base64 of whole .p8, else bare body
    end

  # Strip any "-----…-----" PEM armor, then keep only base64 characters. This is
  # format-agnostic: works whether the key arrived multi-line, single-line, with
  # spaces, or with the BEGIN/END lines deleted.
  text = text.gsub(/-----[^-]*-----/m, "") if text.include?("PRIVATE KEY")
  body = text.gsub(%r{[^A-Za-z0-9+/=]}, "")
  pem = "-----BEGIN PRIVATE KEY-----\n" + body.scan(/.{1,64}/).join("\n") +
    "\n-----END PRIVATE KEY-----"

  # Fail fast with a clear, safe message (no key material) if the reconstructed
  # key can't be parsed — almost always a truncated or mis-pasted secret.
  begin
    OpenSSL::PKey.read(pem)
  rescue StandardError => e
    UI.user_error!(
      "ASC_KEY_P8 is not a valid private key (#{e.message}). " \
      "After cleanup the key body is #{body.length} base64 chars — a real App " \
      "Store Connect key is ~184. Re-create the secret: open the downloaded " \
      "AuthKey_XXXXXX.p8 in a text editor, Select-All, and paste the ENTIRE " \
      "contents (including the BEGIN/END PRIVATE KEY lines) with nothing " \
      "trimmed or added."
    )
  end
  pem
end

# Print a SAFE summary of the secrets seen by the runner — lengths and presence
# only, never the values. Pinpoints "secret not reaching the workflow" (length 0
# = wrong scope/name) vs "secret present but malformed" (length > 0).
def log_secret_diagnostics
  %w[ASC_KEY_ID ASC_ISSUER_ID ASC_KEY_P8 APP_BUNDLE_ID APPLE_TEAM_ID].each do |name|
    v = ENV[name]
    state =
      if v.nil? then "NOT SET"
      elsif v.strip.empty? then "EMPTY (length #{v.length})"
      else "set, #{v.strip.length} chars#{name == 'ASC_KEY_P8' ? ", has-header=#{v.include?('PRIVATE KEY')}" : ''}"
      end
    UI.message("🔑 #{name}: #{state}")
  end
end

# Build the App Store Connect API key object used for every ASC interaction.
def asc_api_key
  log_secret_diagnostics
  raw = ENV["ASC_KEY_P8"].to_s
  if raw.strip.empty?
    UI.user_error!(
      "ASC_KEY_P8 is empty / not set on this runner (length #{raw.length}). The " \
      "key text isn't reaching the workflow, so this is a secret SCOPE or NAME " \
      "problem, not the key itself. Check: (1) it's under Settings → Secrets and " \
      "variables → Actions → 'Repository secrets' (NOT an Environment secret, NOT " \
      "an Organization secret without repo access, NOT a 'Variable'); (2) the name " \
      "is exactly ASC_KEY_P8 with no trailing space or case change; (3) you clicked " \
      "'Update secret' / 'Add secret' to save it."
    )
  end

  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: clean_p8_pem(raw),
    is_key_content_base64: false,
    in_house: false
  )
end

platform :ios do
  # Fast preflight: proves the API key authenticates and can read this app's
  # builds, before anyone spends ~15 minutes on a real archive. Run this lane
  # first whenever you change a secret.
  desc "Verify the App Store Connect secrets without building"
  lane :validate_secrets do
    latest = latest_testflight_build_number(
      api_key: asc_api_key,
      app_identifier: bundle_id,
      initial_build_number: 0
    )
    UI.success("✅ Secrets OK — API key can read TestFlight for #{bundle_id} (latest build: #{latest}).")
  end

  # Build (match-signed) and upload a new build to TestFlight.
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key = asc_api_key
    setup_ci # temporary keychain so match can install the certificate on CI

    # Next build number = highest already on TestFlight + 1 (App Store Connect
    # rejects duplicates). Falls back to 1 for a brand-new app.
    build_number = latest_testflight_build_number(
      api_key: key,
      app_identifier: bundle_id,
      initial_build_number: 0
    ) + 1

    # Reuse ONE distribution certificate + App Store profile, stored encrypted in
    # git, so CI never mints a fresh cert per run (which exhausts Apple's
    # certificate cap). match authenticates to the developer portal with the same
    # App Store Connect API key — no Apple ID password needed.
    match_options = {
      type: "appstore",
      app_identifier: bundle_id,
      api_key: key,
      team_id: team_id,
      storage_mode: "git",
      git_url: ENV.fetch("MATCH_GIT_URL"),
      readonly: false
    }
    # Only pin a branch if asked; otherwise use the certs repo's default branch.
    match_options[:git_branch] = ENV["MATCH_GIT_BRANCH"] unless ENV["MATCH_GIT_BRANCH"].to_s.strip.empty?
    match(match_options)

    profile = "match AppStore #{bundle_id}"
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      # Manual signing with the match-installed profile. CURRENT_PROJECT_VERSION
      # here keeps the pbxproj untouched (no agvtool).
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=#{team_id}",
        "PRODUCT_BUNDLE_IDENTIFIER=#{bundle_id}",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile}",
        "MARKETING_VERSION=1.0",
        "CURRENT_PROJECT_VERSION=#{build_number}"
      ].join(" "),
      export_options: {
        method: "app-store",
        teamID: team_id,
        signingStyle: "manual",
        provisioningProfiles: { bundle_id => profile },
        generateAppStoreInformation: false
      }
    )

    changelog = "Build #{build_number} from #{ENV['GITHUB_REF_NAME'] || 'local'} (#{(ENV['GITHUB_SHA'] || '')[0, 7]})"
    upload_to_testflight(
      api_key: key,
      app_identifier: bundle_id,
      skip_waiting_for_build_processing: true,
      changelog: changelog
    )

    UI.success("✅ Uploaded build #{build_number} to TestFlight. It will appear after Apple finishes processing.")
  end
end
